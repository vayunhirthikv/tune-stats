# App — Spotify requires loopback IP, NOT "localhost" (see README)
AUTH_URL=http://127.0.0.1:3000
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://127.0.0.1:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Spotify Developer Dashboard — https://developer.spotify.com/dashboard
# Spotify Dashboard redirect URI (exact match, HTTP allowed for loopback):
#   http://127.0.0.1:3000/api/auth/callback/spotify
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# PostgreSQL (Vercel Postgres, Neon, Supabase, or local)
DATABASE_URL=postgresql://user:password@localhost:5432/tunestats?schema=public
